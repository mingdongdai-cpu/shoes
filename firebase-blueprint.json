{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory item details",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the product"
        },
        "spec": {
          "type": "integer",
          "description": "Items per box"
        },
        "price": {
          "type": "integer",
          "description": "Price per item"
        },
        "stock": {
          "type": "integer",
          "description": "Total items in stock"
        }
      },
      "required": ["name", "spec", "price", "stock"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Inventory movement record",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string",
          "description": "ID of the related product"
        },
        "type": {
          "type": "string",
          "enum": ["in", "out"],
          "description": "Type of transaction"
        },
        "quantity": {
          "type": "integer",
          "description": "Total items moved"
        },
        "price": {
          "type": "integer",
          "description": "Price at time of transaction"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the transaction"
        },
        "remark": {
          "type": "string",
          "description": "Optional note"
        }
      },
      "required": ["productId", "type", "quantity", "price", "date"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Bookkeeping record",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Date of expense"
        },
        "amount": {
          "type": "number",
          "description": "Amount spent"
        },
        "category": {
          "type": "string",
          "description": "Expense item/category"
        },
        "remark": {
          "type": "string",
          "description": "Optional remark"
        }
      },
      "required": ["date", "amount", "category"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of inventory products"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Collection of stock movements"
    },
    "expenses": {
      "schema": "Expense",
      "description": "Collection of bookkeeping records"
    }
  }
}
